@{
    ViewData["Title"] = "Departman Yönetimi";
}

<div class="page-header mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h3 mb-1">Departman Yönetimi</h1>
        <p class="text-muted mb-0">Hiyerarşik departman yapısını yönetin</p>
    </div>
    <button type="button" class="btn btn-primary" id="btnAddDepartment">Yeni Departman</button>
</div>

<div class="row">
    <div class="col-md-5">
        <div id="departmentsTree"></div>
    </div>
    <div class="col-md-7">
        <div id="departmentDetailCard" class="card k-card">
            <div class="card-header fw-semibold">Departman Detayı</div>
            <div class="card-body">
                <div id="departmentDetailContent" class="text-muted">
                    Sol taraftan bir departman seçin veya yeni departman ekleyin.
                </div>
            </div>
        </div>
    </div>
</div>

<div id="departmentWindow"></div>

@section Scripts {
    <script>
        var selectedDepartment = null;
        var departmentEditMode = "create";

        function onDepartmentSelect(e) {
            selectedDepartment = $("#departmentsTree").data("kendoTreeView").dataItem(e.node);
            renderDepartmentDetail();
        }

        function renderDepartmentDetail() {
            if (!selectedDepartment) return;

            var html = `
                <p><strong>Departman:</strong> ${selectedDepartment.text}</p>
                <div class="mt-3">
                    <button class="btn btn-sm btn-outline-primary me-2" onclick="editDepartment()">Düzenle</button>
                    <button class="btn btn-sm btn-outline-success me-2" onclick="addSubDepartment()">Alt Departman Ekle</button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteDepartment()">Sil</button>
                </div>`;

            $("#departmentDetailContent").html(html);
        }

        function ensureDepartmentDialog() {
            return AppModal.ensure("#departmentWindow", {
                width: "480px",
                title: "Departman",
                deactivate: function () {
                    this.content("");
                }
            });
        }

        function initDepartmentForm(parentId, mode) {
            var $parentGroup = $("#parentDepartmentGroup");
            var $parentSelect = $("#parentDepartmentSelect");

            if (mode === "edit") {
                $parentGroup.hide();
                return;
            }

            $parentGroup.show();

            if ($parentSelect.data("kendoDropDownList")) {
                $parentSelect.data("kendoDropDownList").destroy();
                $parentSelect.empty();
            }

            $parentSelect.kendoDropDownList({
                optionLabel: "Üst seviye (kök departman)",
                dataTextField: "name",
                dataValueField: "id",
                value: parentId || "",
                dataSource: {
                    transport: {
                        read: {
                            url: '@Url.Action("GetDepartments", "Employees")',
                            dataType: "json"
                        }
                    }
                }
            });
        }

        function openDepartmentWindow(title, name, parentId, mode) {
            departmentEditMode = mode;

            var dialog = ensureDepartmentDialog();
            dialog.title(title);
            dialog.content(`
                <form class="p-3" id="departmentForm">
                    <div class="mb-3" id="parentDepartmentGroup">
                        <label class="form-label" for="parentDepartmentSelect">Üst Departman</label>
                        <input id="parentDepartmentSelect" style="width: 100%;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="departmentName">Departman Adı *</label>
                        <input id="departmentName" class="k-textbox w-100" value="${name || ""}" />
                    </div>
                    <div class="text-end">
                        <button type="button" class="btn btn-secondary me-2" id="btnCancelDepartment">İptal</button>
                        <button type="button" class="btn btn-primary" id="btnSaveDepartment">Kaydet</button>
                    </div>
                </form>`);

            AppModal.open(dialog, function () {
                initDepartmentForm(parentId, mode);
                $("#departmentName").trigger("focus");
            });
        }

        function closeDepartmentWindow() {
            ensureDepartmentDialog().close();
        }

        function saveDepartment() {
            var name = $.trim($("#departmentName").val());

            if (!name) {
                showNotification("Departman adı zorunludur.", "error");
                return;
            }

            var parentDepartmentId = null;

            if (departmentEditMode !== "edit") {
                var dropdown = $("#parentDepartmentSelect").data("kendoDropDownList");
                var selectedParentId = dropdown ? dropdown.value() : "";
                parentDepartmentId = selectedParentId || null;
            }

            if (departmentEditMode === "edit") {
                $.ajax({
                    url: '@Url.Action("Update", "Departments")',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({ id: selectedDepartment.id, name: name }),
                    success: function (response) {
                        showNotification(response.message, "success");
                        closeDepartmentWindow();
                        refreshTree();
                    },
                    error: function (xhr) {
                        showNotification(getErrorMessage(xhr), "error");
                    }
                });
            } else {
                $.ajax({
                    url: '@Url.Action("Create", "Departments")',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        name: name,
                        parentDepartmentId: parentDepartmentId
                    }),
                    success: function (response) {
                        showNotification(response.message, "success");
                        closeDepartmentWindow();
                        refreshTree();
                    },
                    error: function (xhr) {
                        showNotification(getErrorMessage(xhr), "error");
                    }
                });
            }
        }

        function editDepartment() {
            if (!selectedDepartment) return;
            openDepartmentWindow("Departman Düzenle", selectedDepartment.text, "", "edit");
        }

        function addSubDepartment() {
            if (!selectedDepartment) return;
            openDepartmentWindow("Alt Departman Ekle", "", selectedDepartment.id, "create");
        }

        function deleteDepartment() {
            if (!selectedDepartment) return;
            if (!confirm("Bu departmanı silmek istediğinize emin misiniz?")) return;

            $.post('@Url.Action("Delete", "Departments")', { id: selectedDepartment.id })
                .done(function (response) {
                    showNotification(response.message, "success");
                    selectedDepartment = null;
                    $("#departmentDetailContent").html("Sol taraftan bir departman seçin veya yeni departman ekleyin.");
                    refreshTree();
                })
                .fail(function (xhr) {
                    showNotification(getErrorMessage(xhr), "error");
                });
        }

        function initializeDepartmentsTree(data) {
            var $tree = $("#departmentsTree");
            var treeView = $tree.data("kendoTreeView");

            if (treeView) {
                treeView.destroy();
                $tree.empty();
            }

            $tree.kendoTreeView({
                loadOnDemand: false,
                dataTextField: "text",
                dataSource: new kendo.data.HierarchicalDataSource({
                    data: data,
                    schema: {
                        model: {
                            id: "id",
                            children: "items",
                            hasChildren: "hasChildren",
                            expanded: "expanded",
                            fields: {
                                text: { type: "string" },
                                id: { type: "string" }
                            }
                        }
                    }
                }),
                select: onDepartmentSelect
            });
        }

        function refreshTree() {
            $.getJSON('@Url.Action("ReadTree", "Departments")')
                .done(function (data) {
                    initializeDepartmentsTree(data);
                })
                .fail(function (xhr) {
                    showNotification(getErrorMessage(xhr), "error");
                });
        }

        $(function () {
            $("#btnAddDepartment").on("click", function () {
                openDepartmentWindow("Yeni Departman", "", "", "create");
            });

            $(document).on("click", "#btnSaveDepartment", saveDepartment);
            $(document).on("click", "#btnCancelDepartment", closeDepartmentWindow);

            refreshTree();
        });
    </script>
}
